# ============================================================
# Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Application ---
PROJECT_NAME=FastAPI App
API_V1_PREFIX=/api/v1
DEBUG=false

# --- Database ---
# SQLite (default, good for development)
DATABASE_URL=sqlite:///./test.db
# PostgreSQL (production example):
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# --- JWT Authentication ---
# IMPORTANT: Generate a real secret key for production!
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# Comma-separated list of allowed origins, or ["*"] for all
# Example: ["http://localhost:3000","https://myapp.com"]
BACKEND_CORS_ORIGINS=["*"]

# --- Distributed Agent Tasks ---
# Configure a reachable Redis instance. The API and Celery Worker must use the
# same broker/result backend URLs. Do not leave localhost here unless Redis is
# actually running on this machine.
CELERY_BROKER_URL=redis://:your-password@192.168.111.128:6379/0
CELERY_RESULT_BACKEND=redis://:your-password@192.168.111.128:6379/1
CELERY_BROKER_CONNECTION_TIMEOUT=5.0
CELERY_TASK_ALWAYS_EAGER=false

# --- Agent Model Provider ---
AGENT_MODEL_SPEC=openai:mimo-v2.5-pro
AGENT_MODEL_BASE_URL=https://sub2api-plus.zeabur.app/v1
AGENT_MODEL_API_KEY=
