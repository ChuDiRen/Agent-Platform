# ============================================================
# Frontend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Environment mode ---
# "development" or "production" — controls base URL selection and build output
VITE_ENV=development

# --- Backend API URL ---
# Used as the base URL for API requests in both dev and production.
# In development, leave empty to use the Vite proxy (/api -> localhost:8000).
# In production, set to your deployed backend URL.
VITE_APP_WEB_URL=

# --- Proxy target (development) ---
# The backend server URL that the Vite dev proxy forwards /api requests to.
# Default: http://localhost:8000
VITE_PROXY_TARGET=http://localhost:8000
